# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:4200

# PostgreSQL connection
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=agile_sprint_board

